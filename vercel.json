{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/[...catchall].js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
